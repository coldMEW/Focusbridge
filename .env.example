# Copy this file to .env.local for local development. .env.local is ignored by git.
# Google OAuth client IDs are public identifiers, not client secrets.
FOCUSBRIDGE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
FOCUSBRIDGE_AUTH_TOKEN_SECRET=replace-with-32-random-bytes-hex
FOCUSBRIDGE_RESEND_API_KEY=your-resend-api-key
FOCUSBRIDGE_OTP_EMAIL_FROM=FocusBridge <verify@your-domain.example>

# Firebase web client config is public client configuration, not a server secret.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=optional-measurement-id
